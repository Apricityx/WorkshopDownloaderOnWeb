{
  "include": ["vite.config.*"],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true
  }
}
